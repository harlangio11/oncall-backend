# Copy this to .env and fill in your values (never commit .env to git)

# APNs credentials — from Apple Developer portal → Keys
APNS_KEY="-----BEGIN PRIVATE KEY-----
...paste your .p8 file content here...
-----END PRIVATE KEY-----"
APNS_KEY_ID=ABC1234567
APNS_TEAM_ID=ABCDE12345
APNS_BUNDLE_ID=com.harlangiordano.oncall
APNS_PRODUCTION=false

# Your Twilio Auth Token (for webhook signature validation — optional but recommended)
TWILIO_AUTH_TOKEN=your_auth_token_here
