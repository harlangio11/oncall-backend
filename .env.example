# Copy this to .env for local dev. In production, set these in Railway dashboard.

# ─── Auto-set by Railway ──────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=postgresql://...   # Set automatically when you add Postgres plugin in Railway

# ─── Generate yourself ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-string   # e.g.: openssl rand -hex 32
APP_URL=https://scintillating-ambition-production-e638.up.railway.app

# ─── APNs ─────────────────────────────────────────────────────────────────────
APNS_KEY="-----BEGIN PRIVATE KEY-----
...paste .p8 content here...
-----END PRIVATE KEY-----"
APNS_KEY_ID=5WQ9ZD4Z7M
APNS_TEAM_ID=UH32FAHQGX
APNS_BUNDLE_ID=com.harlangiordano.oncall
APNS_PRODUCTION=false

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AREA_CODE=415

# ─── Google / Gmail ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
